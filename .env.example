# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Seed Admin ───────────────────────────────────────
# These credentials are used to create the first admin on startup
ADMIN_EMAIL=admin@zorvyn.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Super Admin

# ─── Database ─────────────────────────────────────────
# SQLite file will be created at this path (relative to project root)
DB_PATH=./data/finance.db
